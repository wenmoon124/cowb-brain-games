{
  "name": "brainverse",
  "private": true,
  "packageManager": "pnpm@latest",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @brainverse/web dev",
    "build": "pnpm --filter @brainverse/web build",
    "typecheck": "pnpm --filter @brainverse/web typecheck",
    "lint": "pnpm --filter @brainverse/web lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deploy:web": "pnpm --filter @brainverse/web deploy"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  }
}
