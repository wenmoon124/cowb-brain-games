{
  "name": "brainverse",
  "private": true,
  "packageManager": "pnpm@latest",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @brainverse/web dev\" \"pnpm --filter @brainverse/api dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @brainverse/api db:migrate",
    "db:generate": "pnpm --filter @brainverse/api db:generate",
    "deploy:web": "pnpm --filter @brainverse/web deploy",
    "deploy:api": "pnpm --filter @brainverse/api deploy"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "concurrently": "^8.2.0"
  }
}
